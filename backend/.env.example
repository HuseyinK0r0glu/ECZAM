# ECZAM backend environment — copy to `.env` and fill in.
# Never commit the real `.env` (see root .gitignore). Secrets stay out of source.
# These names match the placeholders in src/main/resources/application.yml.

# ── App ──
PORT=8080
# Dev CORS origin (Flutter web / old React dev server). Native apps ignore CORS.
FRONTEND_URL=http://localhost:5173

# ── Database (matches docker-compose.yml) ──
DATABASE_NAME=eczam
DATABASE_URL=jdbc:postgresql://localhost:5432/eczam
DATABASE_USER=eczam
DATABASE_PASSWORD=eczam

# ── Auth ──
# Generate a long random secret (≥32 bytes): `openssl rand -base64 48`
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes
# Access/refresh/reset TTLs are configured in application.yml (PT2H / P7D / PT30M).
# Google Sign-In (optional) — OAuth 2.0 client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=

# ── AI ──
ANTHROPIC_API_KEY=          # assistant (claude-sonnet-4-6)
OPENAI_API_KEY=             # embeddings (text-embedding-3-small) — or swap a local model

# ── Web Push (browser clients only; native uses local notifications) ──
# Generate once: `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@eczam.app

# ── Email (optional, for low-stock / expiry digests) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Medications dataset seed (one-time; see plans/medications-schema-plan.md) ──
# Stage A imports the catalog; Stage B (needs OPENAI_API_KEY) embeds real leaflets.
SEED_CATALOG=false
SEED_CATALOG_FILE=          # absolute path to the uncompressed ilac.json (or /seed/ilac.json in Docker)
SEED_EMBEDDINGS=false
# Host directory bind-mounted read-only to /seed in the backend container.
SEED_DATA_DIR=./seed-data
