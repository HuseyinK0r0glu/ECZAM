# ECZAM backend environment — copy to `.env` and fill in.
# Never commit the real `.env` (see root .gitignore). Secrets stay out of source.

# App
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:5173

# Database (matches docker-compose.yml)
DATABASE_URL=jdbc:postgresql://localhost:5432/eczam
DATABASE_USER=eczam
DATABASE_PASSWORD=eczam

# Auth — generate a long random secret: `openssl rand -base64 48`
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes
JWT_EXPIRES_IN=7d

# Web Push (Phase 4) — generate once: `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@eczam.app

# AI (Phase 5)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=            # embeddings (text-embedding-3-small) — or swap a local model

# Redis (optional, Phase 4 scheduler clustering)
REDIS_URL=redis://localhost:6379

# Email (optional, Phase 4)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
